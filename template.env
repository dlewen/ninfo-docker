DJANGO_ALLOWED_HOSTS="ninfo.example.com"

DJANGO_SUPERUSER_USERNAME="nadmin"
DJANGO_SUPERUSER_PASSWORD="CHANGETHISDUXN7bqMkuZ8"
DJANGO_SUPERUSER_EMAIL="email@address"
DJANGO_SECRET_KEY='changethishvZMSmFVD7GHhvZMSmFVD7GHhvZMSmFVD7GH'
# Do not use debug in production
DJANGO_DEBUG=True
# Add this line if you're not using HTTPS:
# DJANGO_URL_SCHEME=http

# SSO / OIDC authentication (optional — remove OIDC_RP_CLIENT_ID to disable)
# See README.md for Keycloak and Azure Entra examples.
# OIDC_RP_CLIENT_ID=ninfo
# OIDC_RP_CLIENT_SECRET=your-client-secret
# OIDC_OP_AUTHORIZATION_ENDPOINT=https://idp.example.com/auth
# OIDC_OP_TOKEN_ENDPOINT=https://idp.example.com/token
# OIDC_OP_USER_ENDPOINT=https://idp.example.com/userinfo
# OIDC_OP_JWKS_ENDPOINT=https://idp.example.com/certs
# OIDC_OP_END_SESSION_ENDPOINT=https://idp.example.com/logout

# Session lifetime and OIDC token refresh (optional — defaults shown)
# SESSION_COOKIE_AGE=1209600               # 2 weeks in seconds
# OIDC_RENEW_ID_TOKEN_EXPIRY_SECONDS=900   # 15 minutes in seconds

# Multi-search plugin visibility (optional — defaults: all shown and checked)
# NINFO_MULTI_DEFAULT_PLUGINS=cymruwhois,shodan   # comma-separated; if unset, all checked
# NINFO_MULTI_HIDDEN_PLUGINS=                     # comma-separated plugins to hide entirely

# Settings dropdown links (optional)
# NINFO_MCP_URL=https://ninfo-mcp.example.com
# NINFO_CUSTOM_LINK_LABEL=CLI Client
# NINFO_CUSTOM_LINK_URL=https://github.com/dlewen/ninfocli

# Comma-separated list of ninfo-plugin git repos to include
# Recommended default plugins (uncomment to use):
CUSTOM_GIT_REPOS="https://github.com/JustinAzoff/ninfo-plugin-cymruwhois.git,https://github.com/dlewen/ninfo-plugin-shodan-internetdb.git"
# Or leave empty and add your own:
# CUSTOM_GIT_REPOS=""
